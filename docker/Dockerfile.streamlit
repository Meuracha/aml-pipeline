FROM python:3.11-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit==1.31.0 \
    pandas==2.1.0 \
    psycopg2-binary==2.9.9 \
    plotly==5.18.0 \
    requests==2.31.0

COPY src/ /app/src/

EXPOSE 8501

CMD ["streamlit", "run", "/app/src/dashboard/app.py", "--server.address", "0.0.0.0"]